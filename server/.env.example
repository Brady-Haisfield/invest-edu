ANTHROPIC_API_KEY=sk-ant-your-key-here
FINNHUB_API_KEY=your-finnhub-key-here
# Free API key — register instantly at https://fred.stlouisfed.org/docs/api/api_key.html
# Used for live US Treasury yields, Shiller CAPE, S&P 500 dividend yield, and inflation expectations.
# Falls back to hardcoded rates if missing.
FRED_API_KEY=your-fred-api-key-here
# Financial Modeling Prep — analyst EPS estimates (stocks) and expense ratios (ETFs).
# Free tier: 250 requests/day. Register at https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your-fmp-api-key-here
# Alpha Vantage — fallback for dividend yield, beta, revenue growth when Finnhub returns null.
# Free tier: 25 requests/day. Register at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here
# Secret used to sign JWTs — change this to a long random string in production
AUTH_SECRET=your-secret-key-change-this
PORT=3001
