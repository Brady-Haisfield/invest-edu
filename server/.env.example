ANTHROPIC_API_KEY=sk-ant-your-key-here
FINNHUB_API_KEY=your-finnhub-key-here
# Free API key — register at https://fred.stlouisfed.org/docs/api/api_key.html
# Used for live US Treasury yield data (bond ETF projections). Falls back to hardcoded rates if missing.
FRED_API_KEY=your-fred-api-key-here
FMP_API_KEY=your_fmp_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# Supabase — find these in your Supabase project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Production frontend URL — used to whitelist CORS origin on Railway. Leave blank in local dev.
CORS_ORIGIN=
PORT=3001
